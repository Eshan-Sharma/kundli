<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/m_root" android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="@drawable/widget_bg" android:padding="10dp">
    <TextView android:id="@+id/m_date" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColor="@color/accent" android:textStyle="bold" android:textSize="13sp" android:paddingBottom="4dp"/>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Abhijit" android:textColor="@color/good" android:textSize="10sp"/>
        <TextView android:id="@+id/m_abhijit" android:layout_width="0dp" android:layout_weight="2" android:layout_height="wrap_content" android:textColor="@color/good" android:textSize="11sp"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Brahma" android:textColor="@color/good" android:textSize="10sp"/>
        <TextView android:id="@+id/m_brahma" android:layout_width="0dp" android:layout_weight="2" android:layout_height="wrap_content" android:textColor="@color/good" android:textSize="11sp"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal" android:paddingTop="3dp">
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Rahu" android:textColor="@color/bad" android:textSize="10sp"/>
        <TextView android:id="@+id/m_rahu" android:layout_width="0dp" android:layout_weight="2" android:layout_height="wrap_content" android:textColor="@color/bad" android:textSize="11sp"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Yama" android:textColor="@color/bad" android:textSize="10sp"/>
        <TextView android:id="@+id/m_yama" android:layout_width="0dp" android:layout_weight="2" android:layout_height="wrap_content" android:textColor="@color/bad" android:textSize="11sp"/>
    </LinearLayout>
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:orientation="horizontal">
        <TextView android:layout_width="0dp" android:layout_weight="1" android:layout_height="wrap_content" android:text="Gulika" android:textColor="@color/bad" android:textSize="10sp"/>
        <TextView android:id="@+id/m_gulika" android:layout_width="0dp" android:layout_weight="2" android:layout_height="wrap_content" android:textColor="@color/bad" android:textSize="11sp"/>
    </LinearLayout>
</LinearLayout>
